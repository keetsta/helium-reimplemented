+// Cross-device sync of the extension list and bookmarks via the self-hosted
+// sync service. `kHeliumSyncEnabled` is the master toggle; the per-collection
+// toggles gate what is synced. `kHeliumSyncToken` is the device-generated
+// shared secret that identifies this user's namespace on the server. The
+// `*_version` prefs hold the last server version seen per collection, used for
+// optimistic-concurrency PUTs. `kHeliumSyncLastStatus` / `kHeliumSyncLastTime`
+// back the status shown in settings and onboarding.
+inline constexpr char kHeliumSyncEnabled[] =
+    "helium.services.sync";
+
+inline constexpr char kHeliumSyncToken[] =
+    "helium.services.sync_token";
+
+inline constexpr char kHeliumSyncExtensionsEnabled[] =
+    "helium.services.sync_extensions";
+
+inline constexpr char kHeliumSyncBookmarksEnabled[] =
+    "helium.services.sync_bookmarks";
+
+inline constexpr char kHeliumSyncExtensionsVersion[] =
+    "helium.services.sync_extensions_version";
+
+inline constexpr char kHeliumSyncBookmarksVersion[] =
+    "helium.services.sync_bookmarks_version";
+
+inline constexpr char kHeliumSyncLastStatus[] =
+    "helium.services.sync_last_status";
+
+inline constexpr char kHeliumSyncLastTime[] =
+    "helium.services.sync_last_time";
+
+// Tombstone-sync bookkeeping. The baselines are this device's snapshot of what
+// it knew at the last successful sync (key->item dicts), so the engine can tell
+// a local deletion ("was in baseline, gone now") apart from "never had it" and
+// only ever enacts a remote deletion for an item it actually still holds. If a
+// baseline is empty/corrupt the diff degrades to additive-only, never deleting.
+// `kHeliumSyncBookmarkTrash` is the recoverable bin: bookmarks removed because
+// they were deleted on another device land here (never re-synced) until the
+// user restores or purges them.
+inline constexpr char kHeliumSyncBookmarkBaseline[] =
+    "helium.services.sync_bookmark_baseline";
+
+inline constexpr char kHeliumSyncExtensionBaseline[] =
+    "helium.services.sync_extension_baseline";
+
+inline constexpr char kHeliumSyncBookmarkTrash[] =
+    "helium.services.sync_bookmark_trash";
 }  // namespace prefs
 
 #endif  // COMPONENTS_HELIUM_SERVICES_PREF_NAMES_H_
