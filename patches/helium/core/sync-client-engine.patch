+#include "components/helium_sync/helium_sync_service.h"
+
+#include <set>
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/json/json_reader.h"
+#include "base/json/json_writer.h"
+#include "base/location.h"
+#include "base/logging.h"
+#include "base/strings/utf_string_conversions.h"
+#include "base/time/time.h"
+#include "components/bookmarks/browser/bookmark_model.h"
+#include "components/bookmarks/browser/bookmark_node.h"
+#include "components/bookmarks/common/bookmark_metrics.h"
+#include "components/helium_services/helium_services_helpers.h"
+#include "components/helium_services/pref_names.h"
+#include "components/prefs/pref_service.h"
+#include "components/prefs/scoped_user_pref_update.h"
+#include "extensions/browser/extension_registry.h"
+#include "extensions/common/extension.h"
+#include "extensions/common/extension_set.h"
+#include "net/base/load_flags.h"
+#include "net/traffic_annotation/network_traffic_annotation.h"
+#include "services/network/public/cpp/resource_request.h"
+#include "services/network/public/cpp/shared_url_loader_factory.h"
+#include "services/network/public/cpp/simple_url_loader.h"
+#include "services/network/public/mojom/url_response_head.mojom.h"
+#include "url/gurl.h"
+
+namespace helium {
+
+namespace {
+
+constexpr char kExtensionsCollection[] = "extensions";
+constexpr char kBookmarksCollection[] = "bookmarks";
+
+constexpr int kMaxFetchRetries = 2;
+constexpr int kFetchTimeoutSeconds = 30;
+constexpr size_t kMaxResponseBytes = 1024 * 1024;  // mirrors server cap
+
+// Debounce window for live (observer-driven) syncs, so a bulk operation such as
+// an import coalesces into a single sync rather than hammering the server.
+constexpr int kDebounceSeconds = 4;
+
+// Interval for the background pull, so a device picks up changes made on another
+// device even when nothing changes locally (the observers only fire on local
+// edits). Also runs shortly after startup via the first timer tick.
+constexpr int kPeriodicSyncSeconds = 5 * 60;
+// Initial pull after startup, kept short so a freshly opened browser converges
+// quickly without waiting a full period.
+constexpr int kStartupSyncSeconds = 10;
+
+// Identifies which permanent folder a bookmark lives under, so it can be
+// restored to the same root on another device.
+constexpr char kRootBar[] = "bar";
+constexpr char kRootOther[] = "other";
+constexpr char kRootMobile[] = "mobile";
+
+// Field separator used to build a stable per-item key from a bookmark's
+// root/path/url. 0x1f (unit separator) never occurs in real paths or urls; the
+// JSON writer escapes it as  so the key round-trips through the server.
+constexpr char kKeySep = '\x1f';
+
+// Keys inside the server blob and the baseline pref.
+constexpr char kItemsKey[] = "items";
+constexpr char kTombstonesKey[] = "tombstones";
+constexpr char kDeletedAtKey[] = "deletedAt";
+
+constexpr net::NetworkTrafficAnnotationTag kSyncTrafficTag =
+    net::DefineNetworkTrafficAnnotation("helium_sync", R"(
+        semantics {
+            sender: "Helium sync"
+            description:
+                "Syncs the user's extension list and bookmarks across their "
+                "own devices through the self-hosted Helium sync service."
+            trigger:
+                "Periodically and on user request when sync is enabled."
+            data:
+                "A bearer token chosen by the user, the list of installed "
+                "extension ids, and bookmark titles/urls."
+            destination: OTHER
+        }
+        policy {
+            cookies_allowed: NO
+            setting: "Controlled by the Helium services sync toggle."
+        })");
+
+std::string JoinPath(const base::ListValue& path) {
+  std::string out;
+  for (const base::Value& segment : path) {
+    if (!segment.is_string()) {
+      continue;
+    }
+    out.push_back(kKeySep);
+    out.append(segment.GetString());
+  }
+  return out;
+}
+
+// Stable identity of a bookmark: location + url, deliberately excluding the
+// title so a rename keeps the same item. Moving a bookmark between folders is
+// modelled as delete+add, which is acceptable.
+std::string BookmarkKey(const std::string& root,
+                        const base::ListValue& path,
+                        const std::string& url) {
+  return root + JoinPath(path) + kKeySep + url;
+}
+
+}  // namespace
+
+HeliumSyncService::HeliumSyncService(
+    PrefService* prefs,
+    bookmarks::BookmarkModel* bookmark_model,
+    extensions::ExtensionRegistry* extension_registry,
+    scoped_refptr<network::SharedURLLoaderFactory> url_loader_factory)
+    : prefs_(prefs),
+      bookmark_model_(bookmark_model),
+      extension_registry_(extension_registry),
+      url_loader_factory_(std::move(url_loader_factory)) {
+  pref_change_registrar_.Init(prefs_);
+  helium::ConfigurePrefChangeRegistrarFor(
+      prefs::kHeliumSyncEnabled, pref_change_registrar_,
+      base::BindRepeating(&HeliumSyncService::OnSyncPrefChanged,
+                          weak_factory_.GetWeakPtr()));
+  // The shared helper only registers kHeliumSyncEnabled; also resync when the
+  // token or per-collection toggles change (e.g. pasting the token last).
+  pref_change_registrar_.Add(
+      prefs::kHeliumSyncToken,
+      base::BindRepeating(&HeliumSyncService::OnSyncPrefChanged,
+                          weak_factory_.GetWeakPtr()));
+  pref_change_registrar_.Add(
+      prefs::kHeliumSyncExtensionsEnabled,
+      base::BindRepeating(&HeliumSyncService::OnSyncPrefChanged,
+                          weak_factory_.GetWeakPtr()));
+  pref_change_registrar_.Add(
+      prefs::kHeliumSyncBookmarksEnabled,
+      base::BindRepeating(&HeliumSyncService::OnSyncPrefChanged,
+                          weak_factory_.GetWeakPtr()));
+
+  // Live sync: a local change to bookmarks or the extension set schedules a
+  // debounced sync so deletions/additions propagate without a manual click.
+  if (bookmark_model_) {
+    bookmark_observation_.Observe(bookmark_model_);
+  }
+  if (extension_registry_) {
+    extension_observation_.Observe(extension_registry_);
+  }
+
+  // Pull from the server on startup and periodically thereafter, so changes
+  // made on other devices arrive without requiring a local edit or a manual
+  // "Sync now". Started unconditionally; OnPeriodicSyncTimer re-checks
+  // ShouldSync each tick and re-arms, so it self-activates when sync is
+  // enabled later even if it was off/unreadable at construction time.
+  StartPeriodicSync();
+}
+
+HeliumSyncService::~HeliumSyncService() = default;
+
+void HeliumSyncService::Shutdown() {
+  debounce_timer_.Stop();
+  poll_timer_.Stop();
+  bookmark_observation_.Reset();
+  extension_observation_.Reset();
+  pref_change_registrar_.RemoveAll();
+}
+
+void HeliumSyncService::OnSyncPrefChanged() {
+  if (helium::ShouldSync(*prefs_)) {
+    SyncNow();
+    StartPeriodicSync();
+  } else {
+    StopPeriodicSync();
+  }
+}
+
+void HeliumSyncService::StartPeriodicSync() {
+  // Kick a near-term pull (covers the startup case), then settle into the
+  // periodic cadence. Re-arming happens in OnPeriodicSyncTimer.
+  poll_timer_.Start(FROM_HERE, base::Seconds(kStartupSyncSeconds),
+                    base::BindOnce(&HeliumSyncService::OnPeriodicSyncTimer,
+                                   weak_factory_.GetWeakPtr()));
+}
+
+void HeliumSyncService::StopPeriodicSync() {
+  poll_timer_.Stop();
+}
+
+void HeliumSyncService::OnPeriodicSyncTimer() {
+  if (helium::ShouldSync(*prefs_)) {
+    SyncNow();
+  }
+  // Re-arm at the steady cadence regardless; ShouldSync is re-checked each tick
+  // so a later enable/disable is honored without needing a pref-change event.
+  poll_timer_.Start(FROM_HERE, base::Seconds(kPeriodicSyncSeconds),
+                    base::BindOnce(&HeliumSyncService::OnPeriodicSyncTimer,
+                                   weak_factory_.GetWeakPtr()));
+}
+
+void HeliumSyncService::ScheduleSync() {
+  if (applying_remote_ || !helium::ShouldSync(*prefs_)) {
+    return;
+  }
+  debounce_timer_.Start(FROM_HERE, base::Seconds(kDebounceSeconds),
+                        base::BindOnce(&HeliumSyncService::SyncNow,
+                                       weak_factory_.GetWeakPtr()));
+}
+
+void HeliumSyncService::BookmarkModelChanged() {
+  ScheduleSync();
+}
+
+void HeliumSyncService::BookmarkModelLoaded(bool ids_reassigned) {
+  // The model is only readable once loaded; kick an initial sync then.
+  ScheduleSync();
+}
+
+void HeliumSyncService::OnExtensionLoaded(
+    content::BrowserContext* browser_context,
+    const extensions::Extension* extension) {
+  ScheduleSync();
+}
+
+void HeliumSyncService::OnExtensionUninstalled(
+    content::BrowserContext* browser_context,
+    const extensions::Extension* extension,
+    extensions::UninstallReason reason) {
+  ScheduleSync();
+}
+
+void HeliumSyncService::SyncNow() {
+  RunSync(/*reset=*/false);
+}
+
+void HeliumSyncService::ResetServerData() {
+  RunSync(/*reset=*/true);
+}
+
+void HeliumSyncService::RunSync(bool reset) {
+  if (!helium::ShouldSync(*prefs_)) {
+    return;
+  }
+  if (collections_in_flight_ > 0) {
+    return;  // already syncing
+  }
+
+  SetStatus(Status::kSyncing);
+
+  if (CollectionEnabled(kExtensionsCollection)) {
+    ++collections_in_flight_;
+    SyncCollection(kExtensionsCollection, reset);
+  }
+  if (CollectionEnabled(kBookmarksCollection)) {
+    ++collections_in_flight_;
+    SyncCollection(kBookmarksCollection, reset);
+  }
+
+  if (collections_in_flight_ == 0) {
+    SetStatus(Status::kIdle);
+  }
+}
+
+bool HeliumSyncService::CollectionEnabled(const std::string& collection) const {
+  if (collection == kExtensionsCollection) {
+    return prefs_->GetBoolean(prefs::kHeliumSyncExtensionsEnabled);
+  }
+  if (collection == kBookmarksCollection) {
+    return prefs_->GetBoolean(prefs::kHeliumSyncBookmarksEnabled);
+  }
+  return false;
+}
+
+int HeliumSyncService::VersionPrefFor(const std::string& collection) const {
+  if (collection == kExtensionsCollection) {
+    return prefs_->GetInteger(prefs::kHeliumSyncExtensionsVersion);
+  }
+  if (collection == kBookmarksCollection) {
+    return prefs_->GetInteger(prefs::kHeliumSyncBookmarksVersion);
+  }
+  return 0;
+}
+
+void HeliumSyncService::StoreVersionFor(const std::string& collection,
+                                        int version) {
+  if (collection == kExtensionsCollection) {
+    prefs_->SetInteger(prefs::kHeliumSyncExtensionsVersion, version);
+  } else if (collection == kBookmarksCollection) {
+    prefs_->SetInteger(prefs::kHeliumSyncBookmarksVersion, version);
+  }
+}
+
+const char* HeliumSyncService::BaselinePrefFor(
+    const std::string& collection) const {
+  if (collection == kExtensionsCollection) {
+    return prefs::kHeliumSyncExtensionBaseline;
+  }
+  return prefs::kHeliumSyncBookmarkBaseline;
+}
+
+void HeliumSyncService::SyncCollection(const std::string& collection,
+                                       bool reset) {
+  GURL url = helium::GetSyncCollectionURL(*prefs_, collection);
+  if (!url.is_valid()) {
+    SetStatus(Status::kError);
+    --collections_in_flight_;
+    return;
+  }
+
+  auto request = std::make_unique<network::ResourceRequest>();
+  request->url = url;
+  request->method = "GET";
+  request->load_flags = net::LOAD_DISABLE_CACHE;
+  request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+  request->headers.SetHeader(
+      "Authorization",
+      "Bearer " + prefs_->GetString(prefs::kHeliumSyncToken));
+
+  auto loader = network::SimpleURLLoader::Create(std::move(request),
+                                                 kSyncTrafficTag);
+  loader->SetTimeoutDuration(base::Seconds(kFetchTimeoutSeconds));
+  loader->SetRetryOptions(kMaxFetchRetries,
+                          network::SimpleURLLoader::RETRY_ON_NETWORK_CHANGE);
+
+  auto* loader_ptr = loader.get();
+  loader_ptr->DownloadToString(
+      url_loader_factory_.get(),
+      base::BindOnce(&HeliumSyncService::OnCollectionFetched,
+                     weak_factory_.GetWeakPtr(), collection, reset,
+                     std::move(loader)),
+      kMaxResponseBytes);
+}
+
+void HeliumSyncService::OnCollectionFetched(
+    const std::string& collection,
+    bool reset,
+    std::unique_ptr<network::SimpleURLLoader> loader,
+    std::optional<std::string> response_body) {
+  if (!response_body) {
+    LOG(ERROR) << "helium_sync: GET " << collection << " failed";
+    SetStatus(Status::kError);
+    --collections_in_flight_;
+    return;
+  }
+
+  auto parsed = base::JSONReader::ReadDict(*response_body, base::JSON_PARSE_RFC);
+  if (!parsed) {
+    LOG(ERROR) << "helium_sync: GET " << collection << " invalid json";
+    SetStatus(Status::kError);
+    --collections_in_flight_;
+    return;
+  }
+
+  int remote_version = parsed->FindInt("version").value_or(0);
+  const base::Value* data = parsed->Find("data");
+
+  // Normalize the server blob into {items, tombstones} maps. The new format is
+  // a dict with those keys; a bare list is the legacy additive format, which we
+  // read as all-live with no tombstones (so a first sync against legacy data
+  // can never delete). data == null means an empty namespace.
+  base::DictValue server_items;
+  base::DictValue server_tombstones;
+  if (data && data->is_dict()) {
+    const base::DictValue& d = data->GetDict();
+    if (const base::DictValue* items = d.FindDict(kItemsKey)) {
+      server_items = items->Clone();
+    }
+    if (const base::DictValue* tombs = d.FindDict(kTombstonesKey)) {
+      server_tombstones = tombs->Clone();
+    }
+  } else if (data && data->is_list()) {
+    // Legacy migration: key each list entry by our scheme.
+    for (const base::Value& entry : data->GetList()) {
+      if (collection == kExtensionsCollection && entry.is_string()) {
+        server_items.Set(entry.GetString(), base::DictValue());
+      } else if (collection == kBookmarksCollection && entry.is_dict()) {
+        const base::DictValue& dict = entry.GetDict();
+        const std::string* url = dict.FindString("url");
+        const std::string* root = dict.FindString("root");
+        const base::ListValue* path = dict.FindList("path");
+        if (!url) {
+          continue;
+        }
+        const base::ListValue empty;
+        server_items.Set(
+            BookmarkKey(root ? *root : kRootOther, path ? *path : empty, *url),
+            dict.Clone());
+      }
+    }
+  }
+
+  base::DictValue new_baseline;
+  base::ListValue to_trash;
+  base::DictValue merged = MergeCollection(collection, server_items,
+                                           server_tombstones, reset,
+                                           &new_baseline, &to_trash);
+
+  base::DictValue payload;
+  payload.Set("data", std::move(merged));
+  payload.Set("baseVersion", remote_version);
+
+  PushCollection(collection, remote_version, std::move(payload),
+                 std::move(new_baseline), std::move(to_trash));
+}
+
+base::DictValue HeliumSyncService::MergeCollection(
+    const std::string& collection,
+    const base::DictValue& server_items,
+    const base::DictValue& server_tombstones,
+    bool reset,
+    base::DictValue* out_new_baseline,
+    base::ListValue* out_to_trash) {
+  const bool is_bookmarks = (collection == kBookmarksCollection);
+  if (collection == kExtensionsCollection) {
+    missing_extensions_.clear();
+  }
+
+  base::DictValue local = LocalItems(collection);
+
+  base::DictValue out_items;
+  base::DictValue out_tombstones;
+
+  // Reset: ignore the server's tombstones/cruft and publish local as the whole
+  // truth. Never deletes locally.
+  if (reset) {
+    out_items = local.Clone();
+    base::DictValue baseline;
+    baseline.Set(kItemsKey, out_items.Clone());
+    baseline.Set(kTombstonesKey, base::DictValue());
+    *out_new_baseline = std::move(baseline);
+    base::DictValue data;
+    data.Set(kItemsKey, std::move(out_items));
+    data.Set(kTombstonesKey, base::DictValue());
+    return data;
+  }
+
+  // Baseline = the last server view this device acknowledged (3-way common
+  // ancestor).
+  const base::DictValue& base_pref = prefs_->GetDict(BaselinePrefFor(collection));
+  const base::DictValue* base_items = base_pref.FindDict(kItemsKey);
+  const base::DictValue* base_tombs = base_pref.FindDict(kTombstonesKey);
+
+  // Union of every key seen anywhere.
+  std::set<std::string> keys;
+  auto collect = [&keys](const base::DictValue& d) {
+    for (auto pair : d) {
+      keys.insert(pair.first);
+    }
+  };
+  collect(local);
+  collect(server_items);
+  collect(server_tombstones);
+  if (base_items) {
+    collect(*base_items);
+  }
+  if (base_tombs) {
+    collect(*base_tombs);
+  }
+
+  enum class State { kLive, kTomb, kAbsent };
+  auto now = base::Time::Now().InSecondsFSinceUnixEpoch();
+
+  for (const std::string& key : keys) {
+    const bool local_present = local.contains(key);
+    const base::DictValue* local_item =
+        local_present ? local.FindDict(key) : nullptr;
+
+    State base_state = State::kAbsent;
+    if (base_items && base_items->contains(key)) {
+      base_state = State::kLive;
+    } else if (base_tombs && base_tombs->contains(key)) {
+      base_state = State::kTomb;
+    }
+
+    State server_state = State::kAbsent;
+    if (server_items.contains(key)) {
+      server_state = State::kLive;
+    } else if (server_tombstones.contains(key)) {
+      server_state = State::kTomb;
+    }
+
+    // The item payload to carry forward, best source first.
+    auto pick_item = [&]() -> base::DictValue {
+      if (local_item) {
+        return local_item->Clone();
+      }
+      if (const base::DictValue* s = server_items.FindDict(key)) {
+        return s->Clone();
+      }
+      if (base_items) {
+        if (const base::DictValue* b = base_items->FindDict(key)) {
+          return b->Clone();
+        }
+      }
+      return base::DictValue();
+    };
+
+    // deletedAt to record on a tombstone (preserve an existing one).
+    auto pick_deleted_at = [&]() -> double {
+      if (const base::DictValue* t = server_tombstones.FindDict(key)) {
+        if (auto v = t->FindDouble(kDeletedAtKey)) {
+          return *v;
+        }
+      }
+      if (base_tombs) {
+        if (const base::DictValue* t = base_tombs->FindDict(key)) {
+          if (auto v = t->FindDouble(kDeletedAtKey)) {
+            return *v;
+          }
+        }
+      }
+      return now;
+    };
+
+    auto emit_live = [&]() {
+      out_items.Set(key, pick_item());
+    };
+    auto emit_tomb = [&]() {
+      base::DictValue t;
+      t.Set(kDeletedAtKey, pick_deleted_at());
+      out_tombstones.Set(key, std::move(t));
+    };
+
+    // Classify the local change relative to the baseline.
+    // For extensions, presence with a tomb baseline is "stale" (we never
+    // uninstall), NOT a re-add; for bookmarks a case-H deletion removes the
+    // node, so presence with a tomb baseline means the user re-created it.
+    if (local_present) {
+      if (base_state == State::kLive) {
+        // KEPT.
+        if (server_state == State::kTomb) {
+          // CASE H: deleted on another device.
+          emit_tomb();
+          if (is_bookmarks) {
+            out_to_trash->Append(pick_item());  // enacted only after a 200
+          }
+          // extensions: honored, never uninstalled, not reported missing.
+        } else {
+          // live, or missing (server lost it / legacy) -> re-assert live.
+          emit_live();
+        }
+      } else if (base_state == State::kTomb && !is_bookmarks) {
+        // Extension still installed though we acknowledged a tombstone. Honor
+        // the tombstone to avoid a resurrection flap, unless another device has
+        // explicitly revived it (server live).
+        if (server_state == State::kLive) {
+          emit_live();
+        } else {
+          emit_tomb();
+        }
+      } else {
+        // ADDED locally (base unknown, or a bookmark re-created after trashing)
+        // -> local presence wins, clearing any server tombstone.
+        emit_live();
+      }
+    } else {
+      if (base_state == State::kLive) {
+        // DELETED locally -> propagate as a tombstone.
+        emit_tomb();
+      } else if (server_state == State::kLive) {
+        // ABSENT locally but present on the server: a remote add (CASE J).
+        if (is_bookmarks) {
+          MaterializeBookmark(*server_items.FindDict(key));
+        } else {
+          missing_extensions_.push_back(key);
+        }
+        emit_live();
+      } else if (server_state == State::kTomb) {
+        emit_tomb();
+      }
+      // else absent everywhere -> drop.
+    }
+  }
+
+  // Remote-add extensions surfaced as "missing" are pushed back live so the
+  // server keeps them, but they are NOT installed on this device. Recording
+  // them as live in our baseline would make the next sync read their local
+  // absence as a deletion and tombstone them, poisoning the server for every
+  // device. Keep them out of the baseline so each sync re-surfaces them as
+  // missing instead of falsely deleting them.
+  base::DictValue baseline_items = out_items.Clone();
+  if (collection == kExtensionsCollection) {
+    for (const std::string& key : missing_extensions_) {
+      baseline_items.Remove(key);
+    }
+  }
+
+  base::DictValue baseline;
+  baseline.Set(kItemsKey, std::move(baseline_items));
+  baseline.Set(kTombstonesKey, out_tombstones.Clone());
+  *out_new_baseline = std::move(baseline);
+
+  base::DictValue data;
+  data.Set(kItemsKey, std::move(out_items));
+  data.Set(kTombstonesKey, std::move(out_tombstones));
+  return data;
+}
+
+void HeliumSyncService::PushCollection(const std::string& collection,
+                                       int base_version,
+                                       base::DictValue payload,
+                                       base::DictValue new_baseline,
+                                       base::ListValue to_trash) {
+  GURL url = helium::GetSyncCollectionURL(*prefs_, collection);
+  if (!url.is_valid()) {
+    SetStatus(Status::kError);
+    --collections_in_flight_;
+    return;
+  }
+
+  std::string body;
+  base::JSONWriter::Write(payload, &body);
+
+  auto request = std::make_unique<network::ResourceRequest>();
+  request->url = url;
+  request->method = "PUT";
+  request->load_flags = net::LOAD_DISABLE_CACHE;
+  request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+  request->headers.SetHeader(
+      "Authorization",
+      "Bearer " + prefs_->GetString(prefs::kHeliumSyncToken));
+  request->headers.SetHeader("Content-Type", "application/json");
+
+  auto loader = network::SimpleURLLoader::Create(std::move(request),
+                                                 kSyncTrafficTag);
+  loader->SetTimeoutDuration(base::Seconds(kFetchTimeoutSeconds));
+  loader->AttachStringForUpload(body, "application/json");
+
+  auto* loader_ptr = loader.get();
+  loader_ptr->DownloadToString(
+      url_loader_factory_.get(),
+      base::BindOnce(&HeliumSyncService::OnCollectionPushed,
+                     weak_factory_.GetWeakPtr(), collection,
+                     std::move(new_baseline), std::move(to_trash),
+                     std::move(loader)),
+      kMaxResponseBytes);
+}
+
+void HeliumSyncService::OnCollectionPushed(
+    const std::string& collection,
+    base::DictValue new_baseline,
+    base::ListValue to_trash,
+    std::unique_ptr<network::SimpleURLLoader> loader,
+    std::optional<std::string> response_body) {
+  --collections_in_flight_;
+
+  int response_code = -1;
+  if (loader->ResponseInfo() && loader->ResponseInfo()->headers) {
+    response_code = loader->ResponseInfo()->headers->response_code();
+  }
+
+  if (response_body && response_code == 200) {
+    auto parsed =
+        base::JSONReader::ReadDict(*response_body, base::JSON_PARSE_RFC);
+    if (parsed) {
+      StoreVersionFor(collection, parsed->FindInt("version").value_or(0));
+    }
+    // The PUT is authoritative now: persist the baseline and only now enact the
+    // deferred deletions (move them to the recoverable trash). A conflict/error
+    // skips both, so nothing is ever destroyed on a failed sync.
+    prefs_->SetDict(BaselinePrefFor(collection), std::move(new_baseline));
+    if (!to_trash.empty()) {
+      applying_remote_ = true;
+      for (const base::Value& item : to_trash) {
+        if (item.is_dict()) {
+          TrashBookmark(item.GetDict());
+        }
+      }
+      applying_remote_ = false;
+    }
+    if (collections_in_flight_ == 0) {
+      SetStatus(Status::kSuccess);
+    }
+    return;
+  }
+
+  // A 409 means another device wrote concurrently. The next sync will re-fetch
+  // the newer version and merge again; we don't auto-loop here.
+  LOG(ERROR) << "helium_sync: PUT " << collection
+             << " failed, code = " << response_code;
+  SetStatus(response_code == 409 ? Status::kConflictRetrying : Status::kError);
+}
+
+base::DictValue HeliumSyncService::LocalItems(
+    const std::string& collection) const {
+  base::DictValue items;
+
+  if (collection == kExtensionsCollection) {
+    if (!extension_registry_) {
+      return items;
+    }
+    for (const auto& extension : extension_registry_->enabled_extensions()) {
+      items.Set(extension->id(), base::DictValue());
+    }
+    return items;
+  }
+
+  if (!bookmark_model_ || !bookmark_model_->loaded()) {
+    return items;
+  }
+
+  struct Frame {
+    const bookmarks::BookmarkNode* node;
+    std::string root;
+    base::ListValue path;
+  };
+  std::vector<Frame> stack;
+  auto push_root = [&](const bookmarks::BookmarkNode* node,
+                       const std::string& root) {
+    if (node) {
+      stack.push_back({node, root, base::ListValue()});
+    }
+  };
+  push_root(bookmark_model_->bookmark_bar_node(), kRootBar);
+  push_root(bookmark_model_->other_node(), kRootOther);
+  push_root(bookmark_model_->mobile_node(), kRootMobile);
+
+  while (!stack.empty()) {
+    Frame frame = std::move(stack.back());
+    stack.pop_back();
+    for (const auto& child : frame.node->children()) {
+      if (child->is_folder()) {
+        base::ListValue child_path = frame.path.Clone();
+        child_path.Append(base::UTF16ToUTF8(child->GetTitle()));
+        stack.push_back({child.get(), frame.root, std::move(child_path)});
+      } else if (child->is_url()) {
+        std::string url = child->url().spec();
+        base::DictValue entry;
+        entry.Set("root", frame.root);
+        entry.Set("path", frame.path.Clone());
+        entry.Set("title", base::UTF16ToUTF8(child->GetTitle()));
+        entry.Set("url", url);
+        items.Set(BookmarkKey(frame.root, frame.path, url), std::move(entry));
+      }
+    }
+  }
+  return items;
+}
+
+const bookmarks::BookmarkNode* HeliumSyncService::FindBookmarkLeaf(
+    const base::DictValue& item) const {
+  if (!bookmark_model_ || !bookmark_model_->loaded()) {
+    return nullptr;
+  }
+  const std::string* url_str = item.FindString("url");
+  const std::string* root_name = item.FindString("root");
+  const base::ListValue* path = item.FindList("path");
+  if (!url_str) {
+    return nullptr;
+  }
+  GURL url(*url_str);
+  if (!url.is_valid()) {
+    return nullptr;
+  }
+
+  const bookmarks::BookmarkNode* current =
+      bookmark_model_->other_node();
+  if (root_name && *root_name == kRootBar) {
+    current = bookmark_model_->bookmark_bar_node();
+  } else if (root_name && *root_name == kRootMobile) {
+    current = bookmark_model_->mobile_node();
+  }
+
+  if (path) {
+    for (const base::Value& segment : *path) {
+      if (!segment.is_string()) {
+        continue;
+      }
+      std::u16string title = base::UTF8ToUTF16(segment.GetString());
+      const bookmarks::BookmarkNode* next = nullptr;
+      for (const auto& child : current->children()) {
+        if (child->is_folder() && child->GetTitle() == title) {
+          next = child.get();
+          break;
+        }
+      }
+      if (!next) {
+        return nullptr;  // folder path doesn't exist -> leaf can't either
+      }
+      current = next;
+    }
+  }
+
+  for (const auto& child : current->children()) {
+    if (child->is_url() && child->url() == url) {
+      return child.get();
+    }
+  }
+  return nullptr;
+}
+
+bool HeliumSyncService::MaterializeBookmark(const base::DictValue& item) {
+  if (!bookmark_model_ || !bookmark_model_->loaded()) {
+    return false;
+  }
+  const std::string* url_str = item.FindString("url");
+  const std::string* title = item.FindString("title");
+  const std::string* root_name = item.FindString("root");
+  const base::ListValue* path = item.FindList("path");
+  if (!url_str) {
+    return false;
+  }
+  GURL url(*url_str);
+  if (!url.is_valid()) {
+    return false;
+  }
+
+  const bookmarks::BookmarkNode* current = bookmark_model_->other_node();
+  if (root_name && *root_name == kRootBar) {
+    current = bookmark_model_->bookmark_bar_node();
+  } else if (root_name && *root_name == kRootMobile) {
+    current = bookmark_model_->mobile_node();
+  }
+
+  const bool prev = applying_remote_;
+  applying_remote_ = true;
+
+  if (path) {
+    for (const base::Value& segment : *path) {
+      if (!segment.is_string()) {
+        continue;
+      }
+      std::u16string folder_title = base::UTF8ToUTF16(segment.GetString());
+      const bookmarks::BookmarkNode* next = nullptr;
+      for (const auto& child : current->children()) {
+        if (child->is_folder() && child->GetTitle() == folder_title) {
+          next = child.get();
+          break;
+        }
+      }
+      if (!next) {
+        next = bookmark_model_->AddFolder(current, current->children().size(),
+                                          folder_title);
+      }
+      current = next;
+    }
+  }
+
+  // Dedupe within the target folder so the same url can live in other folders.
+  for (const auto& child : current->children()) {
+    if (child->is_url() && child->url() == url) {
+      applying_remote_ = prev;
+      return false;
+    }
+  }
+
+  bookmark_model_->AddURL(current, current->children().size(),
+                          base::UTF8ToUTF16(title ? *title : *url_str), url);
+  applying_remote_ = prev;
+  return true;
+}
+
+void HeliumSyncService::TrashBookmark(const base::DictValue& item) {
+  const bookmarks::BookmarkNode* node = FindBookmarkLeaf(item);
+  if (!node) {
+    return;  // already gone locally; nothing to trash
+  }
+
+  base::DictValue entry = item.Clone();
+  entry.Set(kDeletedAtKey, base::Time::Now().InSecondsFSinceUnixEpoch());
+  {
+    ScopedListPrefUpdate update(prefs_, prefs::kHeliumSyncBookmarkTrash);
+    update->Append(std::move(entry));
+  }
+
+  bookmark_model_->Remove(node, bookmarks::metrics::BookmarkEditSource::kOther,
+                          FROM_HERE);
+}
+
+base::ListValue HeliumSyncService::GetTrashItems() const {
+  return prefs_->GetList(prefs::kHeliumSyncBookmarkTrash).Clone();
+}
+
+void HeliumSyncService::RestoreTrashItem(int index) {
+  const base::ListValue& trash =
+      prefs_->GetList(prefs::kHeliumSyncBookmarkTrash);
+  if (index < 0 || static_cast<size_t>(index) >= trash.size()) {
+    return;
+  }
+  const base::Value& entry = trash[index];
+  if (entry.is_dict()) {
+    MaterializeBookmark(entry.GetDict());
+  }
+  {
+    ScopedListPrefUpdate update(prefs_, prefs::kHeliumSyncBookmarkTrash);
+    update->erase(update->begin() + index);
+  }
+  // The re-added bookmark is a fresh local add; the next sync clears the server
+  // tombstone so it comes back on every device.
+  ScheduleSync();
+}
+
+void HeliumSyncService::DeleteTrashItem(int index) {
+  ScopedListPrefUpdate update(prefs_, prefs::kHeliumSyncBookmarkTrash);
+  if (index < 0 || static_cast<size_t>(index) >= update->size()) {
+    return;
+  }
+  update->erase(update->begin() + index);
+}
+
+void HeliumSyncService::EmptyTrash() {
+  prefs_->SetList(prefs::kHeliumSyncBookmarkTrash, base::ListValue());
+}
+
+void HeliumSyncService::SetStatus(Status status) {
+  last_status_ = status;
+  prefs_->SetInteger(prefs::kHeliumSyncLastStatus, static_cast<int>(status));
+  if (status == Status::kSuccess || status == Status::kError) {
+    prefs_->SetDouble(prefs::kHeliumSyncLastTime,
+                      base::Time::Now().InSecondsFSinceUnixEpoch());
+  }
+}
