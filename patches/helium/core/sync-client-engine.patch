+namespace helium {
+
+// Cross-device sync of the extension list and bookmarks against the
+// self-hosted sync service (`{origin}/sync/{collection}`).
+//
+// SAFETY MODEL. This touches user data, so deletions are designed so a bug or
+// accident can never permanently destroy anything:
+//   - The engine keeps a per-collection *baseline* (a pref snapshot of what
+//     this device knew at its last successful sync). A remote deletion is only
+//     ever *enacted* for an item still in our baseline AND still held locally
+//     (see the merge table in the .cc). If the baseline is empty or corrupt,
+//     every item degrades to an "add", so the worst case is additive, never
+//     destructive. The first sync against a fresh/legacy server is thus always
+//     a pure union and cannot delete.
+//   - Bookmarks deleted on another device are moved to a recoverable trash bin
+//     (a pref, never serialized back into the sync blob) before the local node
+//     is removed. The user restores or purges from settings. Only leaf urls are
+//     ever auto-removed; folders are only created, never auto-deleted.
+//   - Extensions are reported, not silently (un)installed. A remote tombstone
+//     only stops the "missing" nag and prevents a locally-present extension
+//     from resurrecting one uninstalled elsewhere; it never uninstalls.
+//
+// The server stores `data` as an opaque blob, so the whole tombstone model is
+// client-side; the server is an untrusted, dumb versioned store.
+class HeliumSyncService : public KeyedService,
+                          public bookmarks::BaseBookmarkModelObserver,
+                          public extensions::ExtensionRegistryObserver {
+ public:
+  // Result of the most recent sync, surfaced to settings/onboarding via prefs.
+  enum class Status : int {
+    kIdle = 0,
+    kSyncing = 1,
+    kSuccess = 2,
+    kError = 3,
+    kConflictRetrying = 4,
+  };
+
+  HeliumSyncService(
+      PrefService* prefs,
+      bookmarks::BookmarkModel* bookmark_model,
+      extensions::ExtensionRegistry* extension_registry,
+      scoped_refptr<network::SharedURLLoaderFactory> url_loader_factory);
+  HeliumSyncService(const HeliumSyncService&) = delete;
+  HeliumSyncService& operator=(const HeliumSyncService&) = delete;
+  ~HeliumSyncService() override;
+
+  // Triggers a full sync of all enabled collections. Safe to call from the UI
+  // ("sync now" button). No-op if syncing is disabled or already in progress.
+  void SyncNow();
+
+  // Overwrites the server with the local state: pushes local items as the live
+  // set with an empty tombstone map, and resets the baseline to local. Use to
+  // purge accumulated cruft/tombstones from the server namespace. Never deletes
+  // anything locally.
+  void ResetServerData();
+
+  // Extension ids present on the server but not installed locally, from the
+  // last completed extensions sync. Drives the "missing extensions" UI.
+  const std::vector<std::string>& GetMissingExtensions() const {
+    return missing_extensions_;
+  }
+
+  Status last_status() const { return last_status_; }
+
+  // Trash bin (deleted-elsewhere bookmarks). Backed by the
+  // kHeliumSyncBookmarkTrash list pref; each entry is {root, path, title, url,
+  // deletedAt}. `index` refers to position in that list.
+  base::ListValue GetTrashItems() const;
+  // Re-adds the trashed bookmark to its original location and removes it from
+  // the trash. The re-add is a fresh local add, so the next sync clears the
+  // server tombstone (the bookmark comes back on every device).
+  void RestoreTrashItem(int index);
+  // Drops a single trash entry without restoring it (stays gone everywhere).
+  void DeleteTrashItem(int index);
+  void EmptyTrash();
+
+  // KeyedService:
+  void Shutdown() override;
+
+  // BaseBookmarkModelObserver:
+  void BookmarkModelChanged() override;
+  void BookmarkModelLoaded(bool ids_reassigned) override;
+
+  // ExtensionRegistryObserver:
+  void OnExtensionLoaded(content::BrowserContext* browser_context,
+                         const extensions::Extension* extension) override;
+  void OnExtensionUninstalled(content::BrowserContext* browser_context,
+                              const extensions::Extension* extension,
+                              extensions::UninstallReason reason) override;
+
+ private:
+  // Shared implementation of SyncNow()/ResetServerData(). `reset` overwrites
+  // the server with local state instead of merging the server's tombstone map.
+  void RunSync(bool reset);
+
+  // One collection's GET -> merge -> PUT round-trip.
+  void SyncCollection(const std::string& collection, bool reset);
+  void OnCollectionFetched(const std::string& collection,
+                           bool reset,
+                           std::unique_ptr<network::SimpleURLLoader> loader,
+                           std::optional<std::string> response_body);
+  void PushCollection(const std::string& collection,
+                      int base_version,
+                      base::DictValue payload,
+                      base::DictValue new_baseline,
+                      base::ListValue to_trash);
+  void OnCollectionPushed(const std::string& collection,
+                          base::DictValue new_baseline,
+                          base::ListValue to_trash,
+                          std::unique_ptr<network::SimpleURLLoader> loader,
+                          std::optional<std::string> response_body);
+
+  // Core tombstone merge for one collection. A standard 3-way merge: `base` is
+  // the baseline pref (the last server view this device acknowledged, as
+  // {items, tombstones}); `server_items`/`server_tombstones` are the current
+  // server view (after legacy-list migration); local presence comes from the
+  // live model/registry. Returns the converged {items, tombstones} to PUT and
+  // fills `out_new_baseline` with that same converged view (persisted only
+  // after a 200). Safe additive mutations (bookmarks case J: materialize a
+  // remote add) are applied inline because they are harmless if the PUT later
+  // fails. The single destructive action (bookmarks case H: an item deleted
+  // elsewhere) is deferred: the bookmark item dicts are appended to
+  // `out_to_trash` and only enacted after a 200, so a conflict/error never
+  // destroys anything. Extensions never change install state.
+  base::DictValue MergeCollection(const std::string& collection,
+                                  const base::DictValue& server_items,
+                                  const base::DictValue& server_tombstones,
+                                  bool reset,
+                                  base::DictValue* out_new_baseline,
+                                  base::ListValue* out_to_trash);
+
+  // Live local state as a key->itemData map (the unit the merge works in).
+  // Bookmarks: key = root\x1f path...\x1f url, item = {root,path,title,url}.
+  // Extensions: key = id, item = {}.
+  base::DictValue LocalItems(const std::string& collection) const;
+
+  // Adds a single bookmark item dict ({root, path, title, url}) to the model at
+  // its recorded location, creating folders as needed and deduping within the
+  // target folder. Returns true if a node was added. Sets applying_remote_.
+  bool MaterializeBookmark(const base::DictValue& item);
+  // Removes the local leaf bookmark matching `item` (if present) and appends it
+  // to the trash pref. Only leaf urls are touched. Sets applying_remote_.
+  void TrashBookmark(const base::DictValue& item);
+  // Non-creating lookup of the leaf url node described by `item`, or nullptr.
+  const bookmarks::BookmarkNode* FindBookmarkLeaf(
+      const base::DictValue& item) const;
+
+  void SetStatus(Status status);
+  void OnSyncPrefChanged();
+  void ScheduleSync();  // debounced trigger from observers
+  // Periodic background pull so a device picks up changes made elsewhere even
+  // when nothing changes locally. Re-armed after every run while sync is on.
+  void StartPeriodicSync();
+  void StopPeriodicSync();
+  void OnPeriodicSyncTimer();
+
+  int VersionPrefFor(const std::string& collection) const;
+  void StoreVersionFor(const std::string& collection, int version);
+  bool CollectionEnabled(const std::string& collection) const;
+  const char* BaselinePrefFor(const std::string& collection) const;
+
+  raw_ptr<PrefService> prefs_;
+  raw_ptr<bookmarks::BookmarkModel> bookmark_model_;
+  raw_ptr<extensions::ExtensionRegistry> extension_registry_;
+  scoped_refptr<network::SharedURLLoaderFactory> url_loader_factory_;
+
+  PrefChangeRegistrar pref_change_registrar_;
+  base::ScopedObservation<bookmarks::BookmarkModel,
+                          bookmarks::BookmarkModelObserver>
+      bookmark_observation_{this};
+  base::ScopedObservation<extensions::ExtensionRegistry,
+                          extensions::ExtensionRegistryObserver>
+      extension_observation_{this};
+  base::OneShotTimer debounce_timer_;
+  // Fires periodic background pulls (see StartPeriodicSync). One-shot and
+  // self-rescheduling so the first tick can use a shorter startup delay than
+  // the steady cadence.
+  base::OneShotTimer poll_timer_;
+
+  std::vector<std::string> missing_extensions_;
+  Status last_status_ = Status::kIdle;
+  int collections_in_flight_ = 0;
+  // True while we mutate the model from a merge/restore, so our own changes
+  // don't re-trigger a sync through the observers.
+  bool applying_remote_ = false;
+
+  base::WeakPtrFactory<HeliumSyncService> weak_factory_{this};
+};
+
+}  // namespace helium
+
+#endif  // COMPONENTS_HELIUM_SYNC_HELIUM_SYNC_SERVICE_H_
