+#define COMPONENTS_HELIUM_SYNC_HELIUM_SYNC_SERVICE_H_
+
+#include <memory>
+#include <string>
+#include <vector>
+
+#include "base/functional/callback.h"
+#include "base/memory/raw_ptr.h"
+#include "base/memory/weak_ptr.h"
+#include "base/values.h"
+#include "components/keyed_service/core/keyed_service.h"
+#include "components/prefs/pref_change_registrar.h"
+
+class PrefService;
+
+namespace bookmarks {
+class BookmarkModel;
+}
+
+namespace extensions {
+class ExtensionRegistry;
+}
+
+namespace network {
+class SharedURLLoaderFactory;
+class SimpleURLLoader;
+}  // namespace network
+
+namespace helium {
+
+// Cross-device sync of the extension list and bookmarks against the
+// self-hosted sync service (`{origin}/sync/{collection}`).
+//
+// This is intentionally conservative because it touches user data:
+//   - Bookmarks are additive only. Remote bookmarks missing locally are added
+//     in their original location (same root and folder path, folders created
+//     as needed); local bookmarks are never deleted to mirror the server.
+//   - Extensions are reported, not silently installed. The set of synced
+//     extension ids is uploaded, and remote ids missing locally are exposed
+//     via GetMissingExtensions() so the UI can offer a user-initiated install.
+//     Silently installing extensions pushed by a server is an attack surface
+//     we deliberately avoid.
+class HeliumSyncService : public KeyedService {
+ public:
+  // Result of the most recent sync, surfaced to settings/onboarding via prefs.
+  enum class Status : int {
+    kIdle = 0,
+    kSyncing = 1,
+    kSuccess = 2,
+    kError = 3,
+    kConflictRetrying = 4,
+  };
+
+  HeliumSyncService(
+      PrefService* prefs,
+      bookmarks::BookmarkModel* bookmark_model,
+      extensions::ExtensionRegistry* extension_registry,
+      scoped_refptr<network::SharedURLLoaderFactory> url_loader_factory);
+  HeliumSyncService(const HeliumSyncService&) = delete;
+  HeliumSyncService& operator=(const HeliumSyncService&) = delete;
+  ~HeliumSyncService() override;
+
+  // Triggers a full sync of all enabled collections. Safe to call from the UI
+  // ("sync now" button). No-op if syncing is disabled or already in progress.
+  void SyncNow();
+
+  // Extension ids present on the server but not installed locally, from the
+  // last completed extensions sync. Drives the "missing extensions" UI.
+  const std::vector<std::string>& GetMissingExtensions() const {
+    return missing_extensions_;
+  }
+
+  Status last_status() const { return last_status_; }
+
+ private:
+  // One collection's GET→merge→PUT round-trip.
+  void SyncCollection(const std::string& collection);
+  void OnCollectionFetched(const std::string& collection,
+                           std::unique_ptr<network::SimpleURLLoader> loader,
+                           std::optional<std::string> response_body);
+  void PushCollection(const std::string& collection,
+                      int base_version,
+                      base::DictValue payload);
+  void OnCollectionPushed(const std::string& collection,
+                          std::unique_ptr<network::SimpleURLLoader> loader,
+                          std::optional<std::string> response_body);
+
+  // Collection (de)serialization. These read/write the live BookmarkModel and
+  // ExtensionRegistry. `remote` is the server's `data` field (may be null).
+  base::ListValue SerializeExtensions() const;
+  void ApplyRemoteExtensions(const base::ListValue& remote);
+
+  base::ListValue SerializeBookmarks() const;
+  void ApplyRemoteBookmarks(const base::ListValue& remote);
+
+  void SetStatus(Status status);
+  void OnSyncPrefChanged();
+
+  int VersionPrefFor(const std::string& collection) const;
+  void StoreVersionFor(const std::string& collection, int version);
+  bool CollectionEnabled(const std::string& collection) const;
+
+  raw_ptr<PrefService> prefs_;
+  raw_ptr<bookmarks::BookmarkModel> bookmark_model_;
+  raw_ptr<extensions::ExtensionRegistry> extension_registry_;
+  scoped_refptr<network::SharedURLLoaderFactory> url_loader_factory_;
+
+  PrefChangeRegistrar pref_change_registrar_;
+  std::vector<std::string> missing_extensions_;
+  Status last_status_ = Status::kIdle;
+  int collections_in_flight_ = 0;
+
+  base::WeakPtrFactory<HeliumSyncService> weak_factory_{this};
+};
+
+}  // namespace helium
+
+#endif  // COMPONENTS_HELIUM_SYNC_HELIUM_SYNC_SERVICE_H_
