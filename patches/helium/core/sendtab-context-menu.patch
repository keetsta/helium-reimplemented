+#ifndef CHROME_BROWSER_UI_TABS_HELIUM_SEND_TAB_MENU_DELEGATE_H_
+#define CHROME_BROWSER_UI_TABS_HELIUM_SEND_TAB_MENU_DELEGATE_H_
+
+#include <string>
+#include <vector>
+
+#include "base/memory/weak_ptr.h"
+#include "chrome/browser/helium_sendtab/helium_sendtab_service.h"
+#include "ui/menus/simple_menu_model.h"
+#include "url/gurl.h"
+
+namespace content {
+class WebContents;
+}
+
+namespace helium {
+
+// Delegate backing the "Send tab to my devices" submenu in the tab context
+// menu. It snapshots the device list and the target tab's url/title at
+// construction, and on selection forwards the tab to the chosen device via
+// HeliumSendTabService.
+class HeliumSendTabMenuDelegate : public ui::SimpleMenuModel::Delegate {
+ public:
+  explicit HeliumSendTabMenuDelegate(content::WebContents* web_contents);
+  HeliumSendTabMenuDelegate(const HeliumSendTabMenuDelegate&) = delete;
+  HeliumSendTabMenuDelegate& operator=(const HeliumSendTabMenuDelegate&) =
+      delete;
+  ~HeliumSendTabMenuDelegate() override;
+
+  // Adds one item per known device to `model`. Returns the number added.
+  size_t PopulateSubmenu(ui::SimpleMenuModel* model);
+
+  // True if at least one device is available to send to.
+  bool HasDevices() const { return !devices_.empty(); }
+
+  // ui::SimpleMenuModel::Delegate:
+  bool IsCommandIdEnabled(int command_id) const override;
+  void ExecuteCommand(int command_id, int event_flags) override;
+
+ private:
+  base::WeakPtr<content::WebContents> web_contents_;
+  GURL url_;
+  std::u16string title_;
+  std::vector<HeliumSendTabService::Device> devices_;
+};
+
+}  // namespace helium
+
+#endif  // CHROME_BROWSER_UI_TABS_HELIUM_SEND_TAB_MENU_DELEGATE_H_
