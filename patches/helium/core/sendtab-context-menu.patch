+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/ui/tabs/helium_send_tab_menu_delegate.h"
+
+#include "base/strings/utf_string_conversions.h"
+#include "chrome/app/chrome_command_ids.h"
+#include "chrome/browser/helium_sendtab/helium_sendtab_service_factory.h"
+#include "chrome/browser/profiles/profile.h"
+#include "content/public/browser/web_contents.h"
+
+namespace helium {
+
+namespace {
+
+HeliumSendTabService* ServiceFor(content::WebContents* web_contents) {
+  if (!web_contents) {
+    return nullptr;
+  }
+  Profile* profile =
+      Profile::FromBrowserContext(web_contents->GetBrowserContext());
+  return HeliumSendTabServiceFactory::GetForProfile(profile);
+}
+
+}  // namespace
+
+HeliumSendTabMenuDelegate::HeliumSendTabMenuDelegate(
+    content::WebContents* web_contents)
+    : web_contents_(web_contents ? web_contents->GetWeakPtr() : nullptr) {
+  if (web_contents) {
+    url_ = web_contents->GetLastCommittedURL();
+    title_ = web_contents->GetTitle();
+  }
+  if (HeliumSendTabService* service = ServiceFor(web_contents)) {
+    devices_ = service->GetDevices();
+  }
+}
+
+HeliumSendTabMenuDelegate::~HeliumSendTabMenuDelegate() = default;
+
+size_t HeliumSendTabMenuDelegate::PopulateSubmenu(ui::SimpleMenuModel* model) {
+  size_t count = 0;
+  for (size_t i = 0; i < devices_.size(); ++i) {
+    int command_id = IDC_HELIUM_SEND_TAB_TO_DEVICE_FIRST + static_cast<int>(i);
+    if (command_id > IDC_HELIUM_SEND_TAB_TO_DEVICE_LAST) {
+      break;  // out of reserved ids; ignore the overflow
+    }
+    model->AddItem(command_id, base::UTF8ToUTF16(devices_[i].name));
+    ++count;
+  }
+  return count;
+}
+
+bool HeliumSendTabMenuDelegate::IsCommandIdEnabled(int command_id) const {
+  return url_.is_valid();
+}
+
+void HeliumSendTabMenuDelegate::ExecuteCommand(int command_id,
+                                               int event_flags) {
+  if (command_id < IDC_HELIUM_SEND_TAB_TO_DEVICE_FIRST ||
+      command_id > IDC_HELIUM_SEND_TAB_TO_DEVICE_LAST) {
+    return;
+  }
+  size_t index = static_cast<size_t>(command_id -
+                                     IDC_HELIUM_SEND_TAB_TO_DEVICE_FIRST);
+  if (index >= devices_.size() || !url_.is_valid()) {
+    return;
+  }
+  if (HeliumSendTabService* service = ServiceFor(web_contents_.get())) {
+    service->SendTab(devices_[index].id, url_, title_);
+  }
+}
+
+}  // namespace helium
