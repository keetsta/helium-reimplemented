+void TabMenuModel::BuildHeliumSendTabSubmenu(int index) {
+  helium_send_tab_submenu_delegate_ =
+      std::make_unique<helium::HeliumSendTabMenuDelegate>(
+          tab_strip_->GetWebContentsAt(index));
+  if (!helium_send_tab_submenu_delegate_->HasDevices()) {
+    helium_send_tab_submenu_delegate_.reset();
+    return;  // nothing to send to; don't show the item
+  }
+  helium_send_tab_submenu_ = std::make_unique<ui::SimpleMenuModel>(
+      helium_send_tab_submenu_delegate_.get());
+  helium_send_tab_submenu_delegate_->PopulateSubmenu(
+      helium_send_tab_submenu_.get());
+  AddSubMenuWithStringId(IDC_HELIUM_SEND_TAB_TO_DEVICE_SUBMENU,
+                         IDS_TAB_CXMENU_HELIUM_SEND_TAB_TO_DEVICE,
+                         helium_send_tab_submenu_.get());
+}
