+  // Helium: a tab was sent to this device from another of the user's devices.
+  // The action button opens the most recently received tab (the toast itself
+  // carries no payload, so the service holds the url).
+  toast_registry_->RegisterToast(
+      ToastId::kHeliumSendTabReceived,
+      ToastSpecification::Builder(vector_icons::kDevicesIcon,
+                                  IDS_HELIUM_SENDTAB_RECEIVED_TOAST_BODY)
+          .AddActionButton(
+              IDS_HELIUM_SENDTAB_RECEIVED_TOAST_ACTION,
+              base::BindRepeating(
+                  [](BrowserWindowInterface* window) {
+                    if (helium::HeliumSendTabService* service =
+                            helium::HeliumSendTabServiceFactory::GetForProfile(
+                                window->GetProfile())) {
+                      service->OpenLastReceivedTab();
+                    }
+                  },
+                  base::Unretained(browser_window_interface)))
+          .AddCloseButton()
+          .AddGlobalScoped()
+          .Build());
 }  // RegisterToasts() end.
