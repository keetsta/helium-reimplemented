+class SharedURLLoaderFactory;
+class SimpleURLLoader;
+}  // namespace network
+
+namespace helium {
+
+// Send-tab-to-device over the self-hosted services instance.
+//
+// Delivery is near-instant via long-poll, with no push server or WebSocket:
+//   - Each device has an inbox at {origin}/sync/sendtab/<deviceId>. Sending a
+//     tab POSTs it there; the server appends it and bumps a sequence number.
+//   - To receive, the device holds a long-poll GET open against its own inbox.
+//     The server (via Deno kv.watch) replies the instant a tab is enqueued, or
+//     with 204 after a timeout, at which point we re-poll. The GET drains the
+//     inbox server-side, so each tab is delivered exactly once.
+//   - A separate device registry blob at {origin}/sync/tabs lets devices learn
+//     each other's names; it is refreshed on a slow timer.
+//
+// Safety: an incoming tab is never opened silently unless the user chose
+// auto-open (kHeliumSendTabReceiveMode). Otherwise it surfaces an in-window
+// toast (falling back to an OS notification when no browser window is open)
+// whose action opens the tab.
+class HeliumSendTabService : public KeyedService {
+ public:
+  struct Device {
+    std::string id;
+    std::string name;
+  };
+
+  HeliumSendTabService(
+      Profile* profile,
+      PrefService* prefs,
+      scoped_refptr<network::SharedURLLoaderFactory> url_loader_factory);
+  HeliumSendTabService(const HeliumSendTabService&) = delete;
+  HeliumSendTabService& operator=(const HeliumSendTabService&) = delete;
+  ~HeliumSendTabService() override;
+
+  // Known peer devices (registry minus this device), from the last refresh.
+  std::vector<Device> GetDevices() const;
+
+  // POSTs `url`/`title` to the inbox of the device with id `device_id`.
+  void SendTab(const std::string& device_id,
+               const GURL& url,
+               const std::u16string& title);
+
+  // Opens the most recently received tab. Invoked by the in-window toast's
+  // action button (which can't carry the url itself).
+  void OpenLastReceivedTab();
+
+  // KeyedService:
+  void Shutdown() override;
+
+ private:
+  // Starts/stops the registry refresh and the inbox long-poll loop based on
+  // whether send-tab is currently enabled.
+  void Restart();
+  void Stop();
+
+  // Device registry (slow timer): publish our entry, read peers.
+  void RefreshRegistry();
+  void OnRegistryFetched(std::unique_ptr<network::SimpleURLLoader> loader,
+                         std::optional<std::string> body);
+  void PushRegistry(int base_version, base::DictValue data);
+  void OnRegistryPushed(std::unique_ptr<network::SimpleURLLoader> loader,
+                        std::optional<std::string> body);
+  void ScheduleRegistryRefresh();
+
+  // Inbox long-poll loop: one outstanding GET at a time; on completion deliver
+  // and immediately re-arm.
+  void PollInbox();
+  void OnInboxResponse(std::unique_ptr<network::SimpleURLLoader> loader,
+                       std::optional<std::string> body);
+
+  void OnSendResponse(std::unique_ptr<network::SimpleURLLoader> loader,
+                      std::optional<std::string> body);
+
+  // Surfaces one received tab per the receive-mode pref.
+  void DeliverTab(const std::string& from_name,
+                  const GURL& url,
+                  const std::u16string& title);
+  // Shows an in-window toast for a received tab. Returns false if there is no
+  // browser window to host it (caller then falls back to an OS notification).
+  bool ShowReceivedTabToast(const std::string& from_name);
+  // Shows an OS notification whose click opens `url` (fallback path).
+  void ShowReceivedTabNotification(const std::string& from_name,
+                                   const GURL& url,
+                                   const std::u16string& title);
+  void OpenTab(const GURL& url);
+
+  std::string DeviceId();    // ours; lazily generated + persisted
+  std::string DeviceName();  // ours; user pref or a platform default
+
+  void OnPrefChanged();
+  // When the user turns sync on, default send-tab on too. Fires only on the
+  // sync-enabled transition, so turning send-tab off afterwards is respected.
+  void OnSyncEnabledChanged();
+
+  raw_ptr<Profile> profile_;
+  raw_ptr<PrefService> prefs_;
+  scoped_refptr<network::SharedURLLoaderFactory> url_loader_factory_;
+
+  PrefChangeRegistrar pref_change_registrar_;
+  base::OneShotTimer registry_timer_;
+  base::OneShotTimer inbox_backoff_timer_;
+  std::vector<Device> devices_;
+
+  // True while send-tab is enabled; gates the long-poll loop and the registry
+  // timer. A single inbox long-poll is kept in flight at a time, tracked by
+  // `inbox_in_flight_` so we never run two concurrent loops.
+  bool running_ = false;
+  bool inbox_in_flight_ = false;
+
+  // The url of the most recently delivered tab, opened by the toast's action
+  // button. Cleared after opening.
+  GURL last_received_url_;
+
+  base::WeakPtrFactory<HeliumSendTabService> weak_factory_{this};
+};
+
+}  // namespace helium
+
+#endif  // CHROME_BROWSER_HELIUM_SENDTAB_HELIUM_SENDTAB_SERVICE_H_
