+#include "base/functional/bind.h"
+#include "base/json/json_reader.h"
+#include "base/json/json_writer.h"
+#include "base/logging.h"
+#include "base/strings/utf_string_conversions.h"
+#include "base/time/time.h"
+#include "base/uuid.h"
+#include "chrome/browser/notifications/notification_display_service.h"
+#include "chrome/browser/notifications/notification_display_service_factory.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/browser_finder.h"
+#include "chrome/browser/ui/browser_window/public/browser_window_features.h"
+#include "chrome/browser/ui/browser_window/public/browser_window_interface.h"
+#include "chrome/browser/ui/navigator/browser_navigator.h"
+#include "chrome/browser/ui/navigator/browser_navigator_params.h"
+#include "chrome/browser/ui/toasts/api/toast_id.h"
+#include "chrome/browser/ui/toasts/toast_controller.h"
+#include "components/helium_services/helium_services_helpers.h"
+#include "components/helium_services/pref_names.h"
+#include "components/prefs/pref_service.h"
+#include "net/base/load_flags.h"
+#include "net/traffic_annotation/network_traffic_annotation.h"
+#include "services/network/public/cpp/resource_request.h"
+#include "services/network/public/cpp/shared_url_loader_factory.h"
+#include "services/network/public/cpp/simple_url_loader.h"
+#include "services/network/public/mojom/url_response_head.mojom.h"
+#include "ui/base/page_transition_types.h"
+#include "ui/base/window_open_disposition.h"
+#include "ui/message_center/public/cpp/notification.h"
+#include "ui/message_center/public/cpp/notification_delegate.h"
+#include "ui/message_center/public/cpp/notifier_id.h"
+
+namespace helium {
+
+namespace {
+
+constexpr size_t kMaxResponseBytes = 256 * 1024;
+// The long-poll holds the connection open server-side (~25s); allow margin.
+constexpr int kInboxTimeoutSeconds = 35;
+constexpr int kRegistryTimeoutSeconds = 30;
+// Re-advertise our presence in the registry on this cadence.
+constexpr int kRegistryRefreshSeconds = 60 * 5;
+// After a transient inbox error, wait before re-arming so we don't hot-loop.
+constexpr int kInboxBackoffSeconds = 10;
+
+constexpr int kDeviceStaleSeconds = 60 * 60 * 24 * 30;  // 30 days
+
+constexpr char kDevicesKey[] = "devices";
+constexpr char kNameKey[] = "name";
+constexpr char kLastSeenKey[] = "lastSeen";
+constexpr char kFromKey[] = "from";
+constexpr char kFromNameKey[] = "fromName";
+constexpr char kToKey[] = "to";
+constexpr char kTitleKey[] = "title";
+constexpr char kUrlKey[] = "url";
+constexpr char kItemsKey[] = "items";
+
+constexpr char kNotifierId[] = "helium.sendtab";
+
+constexpr net::NetworkTrafficAnnotationTag kSendTabTrafficTag =
+    net::DefineNetworkTrafficAnnotation("helium_sendtab", R"(
+        semantics {
+            sender: "Helium send tab to device"
+            description:
+                "Reads and writes a small per-user mailbox on the self-hosted "
+                "Helium services instance so the user can push an open tab to "
+                "another of their own devices, and holds a long-poll request "
+                "open to receive tabs sent to this device."
+            trigger:
+                "While enabled, a long-poll request is kept open to receive "
+                "tabs; a request is also sent when the user picks a device "
+                "from the tab context menu."
+            data:
+                "A user-chosen bearer token, this device's chosen name, and the "
+                "title and url of a tab the user explicitly sends."
+            destination: OTHER
+        }
+        policy {
+            cookies_allowed: NO
+            setting: "Controlled by the Helium services send-to-device toggle."
+        })");
+
+double Now() {
+  return base::Time::Now().InSecondsFSinceUnixEpoch();
+}
+
+std::unique_ptr<network::ResourceRequest> MakeRequest(const GURL& url,
+                                                      const std::string& method,
+                                                      const std::string& token) {
+  auto request = std::make_unique<network::ResourceRequest>();
+  request->url = url;
+  request->method = method;
+  request->load_flags = net::LOAD_DISABLE_CACHE;
+  request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+  request->headers.SetHeader("Authorization", "Bearer " + token);
+  return request;
+}
+
+}  // namespace
+
+HeliumSendTabService::HeliumSendTabService(
+    Profile* profile,
+    PrefService* prefs,
+    scoped_refptr<network::SharedURLLoaderFactory> url_loader_factory)
+    : profile_(profile),
+      prefs_(prefs),
+      url_loader_factory_(std::move(url_loader_factory)) {
+  pref_change_registrar_.Init(prefs_);
+  helium::ConfigurePrefChangeRegistrarFor(
+      prefs::kHeliumSendTabEnabled, pref_change_registrar_,
+      base::BindRepeating(&HeliumSendTabService::OnPrefChanged,
+                          weak_factory_.GetWeakPtr()));
+  pref_change_registrar_.Add(
+      prefs::kHeliumSyncToken,
+      base::BindRepeating(&HeliumSendTabService::OnPrefChanged,
+                          weak_factory_.GetWeakPtr()));
+  pref_change_registrar_.Add(
+      prefs::kHeliumSendTabName,
+      base::BindRepeating(&HeliumSendTabService::OnPrefChanged,
+                          weak_factory_.GetWeakPtr()));
+  pref_change_registrar_.Add(
+      prefs::kHeliumSyncEnabled,
+      base::BindRepeating(&HeliumSendTabService::OnSyncEnabledChanged,
+                          weak_factory_.GetWeakPtr()));
+
+  if (helium::ShouldSendTab(*prefs_)) {
+    Restart();
+  }
+}
+
+HeliumSendTabService::~HeliumSendTabService() = default;
+
+void HeliumSendTabService::Shutdown() {
+  Stop();
+  pref_change_registrar_.RemoveAll();
+}
+
+void HeliumSendTabService::OnPrefChanged() {
+  if (helium::ShouldSendTab(*prefs_)) {
+    Restart();
+  } else {
+    Stop();
+  }
+}
+
+void HeliumSendTabService::OnSyncEnabledChanged() {
+  // Turning sync on opts the user into send-tab as well, as a sensible default.
+  // It's a one-way nudge: we only flip send-tab on when sync goes on, so an
+  // explicit later opt-out of send-tab is preserved. Turning sync off leaves
+  // send-tab untouched.
+  if (prefs_->GetBoolean(prefs::kHeliumSyncEnabled) &&
+      !prefs_->GetBoolean(prefs::kHeliumSendTabEnabled)) {
+    prefs_->SetBoolean(prefs::kHeliumSendTabEnabled, true);
+    // The pref change re-enters OnPrefChanged(), which starts the loops.
+  }
+}
+
+void HeliumSendTabService::Restart() {
+  running_ = true;
+  RefreshRegistry();  // also schedules the next refresh
+  if (!inbox_in_flight_) {
+    PollInbox();
+  }
+}
+
+void HeliumSendTabService::Stop() {
+  running_ = false;
+  registry_timer_.Stop();
+  inbox_backoff_timer_.Stop();
+  // A long-poll already in flight will complete (or its callback will be
+  // dropped via the weak factory); running_ == false stops it re-arming.
+}
+
+std::string HeliumSendTabService::DeviceId() {
+  std::string id = prefs_->GetString(prefs::kHeliumSendTabId);
+  if (id.empty()) {
+    id = base::Uuid::GenerateRandomV4().AsLowercaseString();
+    prefs_->SetString(prefs::kHeliumSendTabId, id);
+  }
+  return id;
+}
+
+std::string HeliumSendTabService::DeviceName() {
+  std::string name = prefs_->GetString(prefs::kHeliumSendTabName);
+  if (!name.empty()) {
+    return name;
+  }
+#if BUILDFLAG(IS_WIN)
+  return "Windows device";
+#elif BUILDFLAG(IS_MAC)
+  return "Mac device";
+#else
+  return "Linux device";
+#endif
+}
+
+std::vector<HeliumSendTabService::Device> HeliumSendTabService::GetDevices()
+    const {
+  return devices_;
+}
+
+// --- Device registry --------------------------------------------------------
+
+void HeliumSendTabService::ScheduleRegistryRefresh() {
+  if (!running_) {
+    return;
+  }
+  registry_timer_.Start(FROM_HERE, base::Seconds(kRegistryRefreshSeconds),
+                        base::BindOnce(&HeliumSendTabService::RefreshRegistry,
+                                       weak_factory_.GetWeakPtr()));
+}
+
+void HeliumSendTabService::RefreshRegistry() {
+  GURL url = helium::GetSendTabURL(*prefs_);
+  if (!url.is_valid()) {
+    return;
+  }
+  auto request =
+      MakeRequest(url, "GET", prefs_->GetString(prefs::kHeliumSyncToken));
+  auto loader =
+      network::SimpleURLLoader::Create(std::move(request), kSendTabTrafficTag);
+  loader->SetTimeoutDuration(base::Seconds(kRegistryTimeoutSeconds));
+  auto* ptr = loader.get();
+  ptr->DownloadToString(
+      url_loader_factory_.get(),
+      base::BindOnce(&HeliumSendTabService::OnRegistryFetched,
+                     weak_factory_.GetWeakPtr(), std::move(loader)),
+      kMaxResponseBytes);
+}
+
+void HeliumSendTabService::OnRegistryFetched(
+    std::unique_ptr<network::SimpleURLLoader> loader,
+    std::optional<std::string> body) {
+  if (!body) {
+    ScheduleRegistryRefresh();
+    return;
+  }
+  auto parsed = base::JSONReader::ReadDict(*body, base::JSON_PARSE_RFC);
+  if (!parsed) {
+    ScheduleRegistryRefresh();
+    return;
+  }
+  int version = parsed->FindInt("version").value_or(0);
+  base::DictValue data;
+  if (const base::DictValue* d = parsed->FindDict("data")) {
+    data = d->Clone();
+  }
+
+  const std::string me = DeviceId();
+  const double now = Now();
+  base::DictValue* devices = data.EnsureDict(kDevicesKey);
+
+  base::DictValue self;
+  self.Set(kNameKey, DeviceName());
+  self.Set(kLastSeenKey, now);
+  devices->Set(me, std::move(self));
+
+  // Drop stale devices and rebuild our local peer list.
+  std::vector<std::string> stale;
+  devices_.clear();
+  for (auto pair : *devices) {
+    if (!pair.second.is_dict()) {
+      continue;
+    }
+    auto seen = pair.second.GetDict().FindDouble(kLastSeenKey);
+    if (seen && *seen < now - kDeviceStaleSeconds) {
+      stale.push_back(pair.first);
+      continue;
+    }
+    if (pair.first != me) {
+      const std::string* name = pair.second.GetDict().FindString(kNameKey);
+      devices_.push_back({pair.first, name ? *name : pair.first});
+    }
+  }
+  for (const std::string& id : stale) {
+    devices->Remove(id);
+  }
+
+  PushRegistry(version, std::move(data));
+}
+
+void HeliumSendTabService::PushRegistry(int base_version, base::DictValue data) {
+  GURL url = helium::GetSendTabURL(*prefs_);
+  if (!url.is_valid()) {
+    ScheduleRegistryRefresh();
+    return;
+  }
+  base::DictValue payload;
+  payload.Set("baseVersion", base_version);
+  payload.Set("data", std::move(data));
+  std::string out;
+  base::JSONWriter::Write(payload, &out);
+
+  auto request =
+      MakeRequest(url, "PUT", prefs_->GetString(prefs::kHeliumSyncToken));
+  request->headers.SetHeader("Content-Type", "application/json");
+  auto loader =
+      network::SimpleURLLoader::Create(std::move(request), kSendTabTrafficTag);
+  loader->SetTimeoutDuration(base::Seconds(kRegistryTimeoutSeconds));
+  loader->AttachStringForUpload(out, "application/json");
+  auto* ptr = loader.get();
+  ptr->DownloadToString(
+      url_loader_factory_.get(),
+      base::BindOnce(&HeliumSendTabService::OnRegistryPushed,
+                     weak_factory_.GetWeakPtr(), std::move(loader)),
+      kMaxResponseBytes);
+}
+
+void HeliumSendTabService::OnRegistryPushed(
+    std::unique_ptr<network::SimpleURLLoader> loader,
+    std::optional<std::string> body) {
+  // A 409 just means another device updated the registry concurrently; the
+  // next scheduled refresh re-reads and re-applies. Nothing else to do.
+  ScheduleRegistryRefresh();
+}
+
+// --- Inbox long-poll --------------------------------------------------------
+
+void HeliumSendTabService::PollInbox() {
+  if (!running_ || inbox_in_flight_) {
+    return;
+  }
+  GURL url = helium::GetSendTabInboxURL(*prefs_, DeviceId());
+  if (!url.is_valid()) {
+    return;
+  }
+
+  auto request =
+      MakeRequest(url, "GET", prefs_->GetString(prefs::kHeliumSyncToken));
+  auto loader =
+      network::SimpleURLLoader::Create(std::move(request), kSendTabTrafficTag);
+  loader->SetTimeoutDuration(base::Seconds(kInboxTimeoutSeconds));
+  inbox_in_flight_ = true;
+  auto* ptr = loader.get();
+  ptr->DownloadToString(
+      url_loader_factory_.get(),
+      base::BindOnce(&HeliumSendTabService::OnInboxResponse,
+                     weak_factory_.GetWeakPtr(), std::move(loader)),
+      kMaxResponseBytes);
+}
+
+void HeliumSendTabService::OnInboxResponse(
+    std::unique_ptr<network::SimpleURLLoader> loader,
+    std::optional<std::string> body) {
+  inbox_in_flight_ = false;
+  if (!running_) {
+    return;
+  }
+
+  int response_code = -1;
+  if (loader->ResponseInfo() && loader->ResponseInfo()->headers) {
+    response_code = loader->ResponseInfo()->headers->response_code();
+  }
+
+  // 204 = long-poll timed out with nothing new: re-arm immediately.
+  if (response_code == 204) {
+    PollInbox();
+    return;
+  }
+
+  // Any transport error or unexpected status: back off, then re-arm.
+  if (!body || response_code != 200) {
+    inbox_backoff_timer_.Start(
+        FROM_HERE, base::Seconds(kInboxBackoffSeconds),
+        base::BindOnce(&HeliumSendTabService::PollInbox,
+                       weak_factory_.GetWeakPtr()));
+    return;
+  }
+
+  auto parsed = base::JSONReader::ReadDict(*body, base::JSON_PARSE_RFC);
+  if (parsed) {
+    const base::ListValue* items = parsed->FindList(kItemsKey);
+    if (items) {
+      for (const base::Value& item : *items) {
+        if (!item.is_dict()) {
+          continue;
+        }
+        const base::DictValue& msg = item.GetDict();
+        const std::string* url_str = msg.FindString(kUrlKey);
+        if (!url_str) {
+          continue;
+        }
+        GURL url(*url_str);
+        if (!url.is_valid()) {
+          continue;
+        }
+        const std::string* from_name = msg.FindString(kFromNameKey);
+        const std::string* title = msg.FindString(kTitleKey);
+        DeliverTab(from_name ? *from_name : std::string(), url,
+                   base::UTF8ToUTF16(title ? *title : std::string()));
+      }
+    }
+  }
+
+  PollInbox();  // immediately re-arm the long-poll
+}
+
+// --- Sending ----------------------------------------------------------------
+
+void HeliumSendTabService::SendTab(const std::string& device_id,
+                                   const GURL& url,
+                                   const std::u16string& title) {
+  if (!helium::ShouldSendTab(*prefs_) || !url.is_valid() ||
+      device_id.empty()) {
+    return;
+  }
+  GURL inbox = helium::GetSendTabInboxURL(*prefs_, device_id);
+  if (!inbox.is_valid()) {
+    return;
+  }
+
+  base::DictValue msg;
+  msg.Set(kFromKey, DeviceId());
+  msg.Set(kFromNameKey, DeviceName());
+  msg.Set(kToKey, device_id);
+  msg.Set(kUrlKey, url.spec());
+  msg.Set(kTitleKey, base::UTF16ToUTF8(title));
+  std::string out;
+  base::JSONWriter::Write(msg, &out);
+
+  auto request =
+      MakeRequest(inbox, "POST", prefs_->GetString(prefs::kHeliumSyncToken));
+  request->headers.SetHeader("Content-Type", "application/json");
+  auto loader =
+      network::SimpleURLLoader::Create(std::move(request), kSendTabTrafficTag);
+  loader->SetTimeoutDuration(base::Seconds(kRegistryTimeoutSeconds));
+  loader->AttachStringForUpload(out, "application/json");
+  auto* ptr = loader.get();
+  ptr->DownloadToString(
+      url_loader_factory_.get(),
+      base::BindOnce(&HeliumSendTabService::OnSendResponse,
+                     weak_factory_.GetWeakPtr(), std::move(loader)),
+      kMaxResponseBytes);
+}
+
+void HeliumSendTabService::OnSendResponse(
+    std::unique_ptr<network::SimpleURLLoader> loader,
+    std::optional<std::string> body) {
+  int response_code = -1;
+  if (loader->ResponseInfo() && loader->ResponseInfo()->headers) {
+    response_code = loader->ResponseInfo()->headers->response_code();
+  }
+  if (response_code != 200) {
+    LOG(ERROR) << "helium_sendtab: send failed, code = " << response_code;
+  }
+}
+
+// --- Delivery ---------------------------------------------------------------
+
+void HeliumSendTabService::DeliverTab(const std::string& from_name,
+                                      const GURL& url,
+                                      const std::u16string& title) {
+  const bool auto_open =
+      prefs_->GetInteger(prefs::kHeliumSendTabReceiveMode) == 1;
+  if (auto_open) {
+    OpenTab(url);
+    return;
+  }
+
+  // Remember the url so the toast's action button (which carries no payload)
+  // can open it. Prefer an in-window toast; if there's no window to host one,
+  // fall back to an OS notification so the tab is never silently dropped.
+  last_received_url_ = url;
+  if (!ShowReceivedTabToast(from_name)) {
+    ShowReceivedTabNotification(from_name, url, title);
+  }
+}
+
+bool HeliumSendTabService::ShowReceivedTabToast(const std::string& from_name) {
+  BrowserWindowInterface* window =
+      chrome::FindLastActiveWithProfile(profile_);
+  if (!window) {
+    return false;
+  }
+  ToastController* controller = window->GetFeatures().toast_controller();
+  if (!controller) {
+    return false;
+  }
+  ToastParams params(ToastId::kHeliumSendTabReceived);
+  // Body: "<device> sent you a tab" — device name fills the placeholder.
+  params.body_string_replacement_params.push_back(
+      from_name.empty() ? u"Another device" : base::UTF8ToUTF16(from_name));
+  return controller->MaybeShowToast(std::move(params));
+}
+
+void HeliumSendTabService::ShowReceivedTabNotification(
+    const std::string& from_name,
+    const GURL& url,
+    const std::u16string& title) {
+  std::u16string source =
+      from_name.empty() ? u"Helium" : base::UTF8ToUTF16(from_name);
+  std::u16string heading = title.empty() ? base::UTF8ToUTF16(url.spec()) : title;
+
+  message_center::RichNotificationData rich;
+  auto delegate =
+      base::MakeRefCounted<message_center::HandleNotificationClickDelegate>(
+          base::BindRepeating(
+              [](base::WeakPtr<HeliumSendTabService> self, GURL url,
+                 std::optional<int>) {
+                if (self) {
+                  self->OpenTab(url);
+                }
+              },
+              weak_factory_.GetWeakPtr(), url));
+
+  std::string id =
+      "helium-sendtab-" + base::Uuid::GenerateRandomV4().AsLowercaseString();
+  message_center::Notification notification(
+      message_center::NOTIFICATION_TYPE_SIMPLE, id, heading,
+      /*message=*/source, ui::ImageModel(),
+      /*display_source=*/u"Helium", url,
+      message_center::NotifierId(message_center::NotifierType::SYSTEM_COMPONENT,
+                                 kNotifierId),
+      rich, std::move(delegate));
+
+  NotificationDisplayServiceFactory::GetForProfile(profile_)->Display(
+      NotificationHandler::Type::TRANSIENT, notification,
+      /*metadata=*/nullptr);
+}
+
+void HeliumSendTabService::OpenLastReceivedTab() {
+  if (last_received_url_.is_valid()) {
+    OpenTab(last_received_url_);
+    last_received_url_ = GURL();
+  }
+}
+
+void HeliumSendTabService::OpenTab(const GURL& url) {
+  NavigateParams params(profile_, url, ui::PAGE_TRANSITION_LINK);
+  params.disposition = WindowOpenDisposition::NEW_FOREGROUND_TAB;
+  Navigate(&params);
+}
