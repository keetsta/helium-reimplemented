+#include "chrome/browser/helium_sendtab/helium_sendtab_service_factory.h"
+
+#include "chrome/browser/helium_sendtab/helium_sendtab_service.h"
+#include "chrome/browser/notifications/notification_display_service_factory.h"
+#include "chrome/browser/profiles/profile.h"
+#include "content/public/browser/browser_context.h"
+#include "content/public/browser/storage_partition.h"
+
+namespace helium {
+
+// static
+HeliumSendTabService* HeliumSendTabServiceFactory::GetForProfile(
+    Profile* profile) {
+  return static_cast<HeliumSendTabService*>(
+      GetInstance()->GetServiceForBrowserContext(profile, /*create=*/true));
+}
+
+// static
+HeliumSendTabServiceFactory* HeliumSendTabServiceFactory::GetInstance() {
+  static base::NoDestructor<HeliumSendTabServiceFactory> instance;
+  return instance.get();
+}
+
+HeliumSendTabServiceFactory::HeliumSendTabServiceFactory()
+    : ProfileKeyedServiceFactory("HeliumSendTabService") {
+  DependsOn(NotificationDisplayServiceFactory::GetInstance());
+}
+
+HeliumSendTabServiceFactory::~HeliumSendTabServiceFactory() = default;
+
+std::unique_ptr<KeyedService>
+HeliumSendTabServiceFactory::BuildServiceInstanceForBrowserContext(
+    content::BrowserContext* context) const {
+  Profile* profile = Profile::FromBrowserContext(context);
+  return std::make_unique<HeliumSendTabService>(
+      profile, profile->GetPrefs(),
+      context->GetDefaultStoragePartition()
+          ->GetURLLoaderFactoryForBrowserProcess());
+}
+
+bool HeliumSendTabServiceFactory::ServiceIsCreatedWithBrowserContext() const {
+  // Create eagerly so polling starts without the UI having to instantiate it.
+  return true;
+}
